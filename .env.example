# Copie este arquivo para `.env` e ajuste se necessário:
#   cp .env.example .env   (Linux/Mac)
#   Copy-Item .env.example .env   (PowerShell)

# Banco de dados PostgreSQL.
# Os valores abaixo batem com o docker-compose.yml padrão (usuário/senha/db = "rinha").
DATABASE_URL="postgresql://rinha:rinha@localhost:5432/rinha"

# Variáveis usadas pelo docker-compose (opcionais — têm defaults iguais aos de cima).
POSTGRES_USER="rinha"
POSTGRES_PASSWORD="rinha"
POSTGRES_DB="rinha"

# NextAuth — gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria-longa"
NEXTAUTH_URL="http://localhost:3000"
