# Copie este arquivo para `.env` e ajuste se necessário:
#   cp .env.example .env   (Linux/Mac)
#   Copy-Item .env.example .env   (PowerShell)

# Banco de dados PostgreSQL.
# Os valores abaixo batem com o docker-compose.yml padrão (usuário/senha/db = "rinha").
DATABASE_URL="postgresql://rinha:rinha@localhost:5432/rinha"

# Variáveis usadas pelo docker-compose (opcionais — têm defaults iguais aos de cima).
POSTGRES_USER="rinha"
POSTGRES_PASSWORD="rinha"
POSTGRES_DB="rinha"

# NextAuth — gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria-longa"
NEXTAUTH_URL="http://localhost:3000"

# ─── Integração com o Discord (login + vínculo de conta via OAuth) ───────────
# Crie uma aplicação em https://discord.com/developers/applications
# e adicione DOIS Redirects em OAuth2:
#   ${NEXTAUTH_URL}/api/auth/callback/discord   (login "Entrar com Discord")
#   ${NEXTAUTH_URL}/api/discord/callback         (vínculo a partir de Minha Conta)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Cifra os tokens OAuth guardados no banco. Gere com: openssl rand -hex 32
# (se ausente, cai no NEXTAUTH_SECRET como fallback)
DISCORD_TOKEN_ENC_KEY=""

# Bot — necessário para auto-join no servidor E para os canais privados por equipe
# (criar canal ao cadastrar equipe, "Solicitar entrada", excluir canal). Sem eles,
# o site funciona normalmente, só não cria/gerencia canais no Discord.
# O bot precisa estar no servidor com permissão de "Gerenciar Canais".
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""

# Opcional — id de uma categoria para agrupar os canais das equipes.
DISCORD_TEAMS_CATEGORY_ID=""
